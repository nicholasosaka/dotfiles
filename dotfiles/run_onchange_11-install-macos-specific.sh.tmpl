#!/bin/sh

{{ if eq .osid "darwin" -}}
echo ""
echo "== Running 11 - Install macOS Specific Packages =="
echo ""
# macOS-specific code
echo "Executing macOS specific installation"

/opt/homebrew/bin/brew bundle --file=/dev/stdin <<EOF
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF

{{- end -}}
