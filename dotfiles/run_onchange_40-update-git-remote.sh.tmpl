#!/bin/sh

echo ""
echo "== Running 40 - Update git Remote =="
echo ""

cd {{ .chezmoi.sourceDir }}

origin_url=$(git remote get-url origin)

case "$origin_url" in
  *github.com*)
    echo "Remote origin uses HTTPS on GitHub"
    
    repo_path="${origin_url#*github.com}"
    repo_path="${repo_path%.git}"
    
    ssh_url="git@github.com$repo_path.git"
    git remote set-url origin "$ssh_url"
    
    echo "Remote origin successfully converted to: $ssh_url"
    ;;
  https://*)
    echo "Remote origin is HTTPS but not GitHub. Skipping conversion."
    ;;
  git@*)
    echo "Remote origin already uses SSH. No conversion needed."
    ;;
  *)
    echo "Unknown or missing remote origin."
    ;;
esac
